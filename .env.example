# =========================
# Datenbank
# =========================
# Standard für Docker Compose mit lokalem Postgres-Container
DATABASE_URL=postgresql+psycopg://dnd:dnd@db:5432/dnd

# =========================
# Sicherheit
# =========================
# Unbedingt durch einen langen zufälligen Wert ersetzen
SECRET_KEY=your-long-random-secret-key-here

# Gültigkeit des Access Tokens in Minuten
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =========================
# CORS / Frontend-Zugriff
# =========================
# Für lokale Entwicklung
BACKEND_CORS_ORIGINS=http://localhost:8080

# Mehrere Origins wären z. B. so:
# BACKEND_CORS_ORIGINS=http://localhost:8080,http://192.168.178.50:8080

# =========================
# Debug
# =========================
# SQL-Logging nur für Debugging aktivieren
DB_ECHO=false